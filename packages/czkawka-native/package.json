{
  "name": "@xiranite/czkawka-native",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Typed Node-API loader for Xiranite's Czkawka Rust core.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "native"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "build:native": "bun scripts/build-native.ts",
    "prepare:embedded": "bun scripts/build-embedded-asset.ts",
    "refresh:prebuilt": "bun scripts/build-embedded-asset.ts --refresh",
    "refresh:prebuilt:existing": "bun scripts/build-embedded-asset.ts --refresh --no-build",
    "smoke:native": "bun run build && bun scripts/smoke-native.mjs",
    "smoke:embedded": "bun run build && bun scripts/smoke-embedded.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^7.0.2"
  }
}
