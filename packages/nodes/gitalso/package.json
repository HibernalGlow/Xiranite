{
  "name": "@xiranite/node-diny",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "Safe commit-message assistant powered by diny, with GitButler-aware guidance.",
  "license": "UNLICENSED",
  "bin": {
    "also": "./dist/cli.js",
    "xdiny": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./help": {
      "types": "./dist/help.d.ts",
      "default": "./dist/help.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "test": "vitest run src"
  },
  "dependencies": {
    "@xiranite/cli-runtime": "workspace:*",
    "@xiranite/config": "workspace:*",
    "@xiranite/contract": "workspace:*",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
