{
  "name": "@xiranite/node-jellypot",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "Jellyfin and PotPlayer launcher node migrated from JellyPot.",
  "license": "UNLICENSED",
  "bin": {
    "xjellypot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./help": {
      "types": "./dist/help.d.ts",
      "default": "./dist/help.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "test": "vitest run src"
  },
  "dependencies": {
    "@xiranite/config": "workspace:*",
    "@xiranite/contract": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
