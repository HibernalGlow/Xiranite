{
  "name": "xiranite",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "packages/*",
    "packages/nodes/*"
  ],
  "scripts": {
    "dev": "bun run build:packages && vite",
    "build": "bun run build:packages && tsc -b && vite build",
    "build:packages": "bun --filter './packages/*' build && bun --filter './packages/nodes/*' build",
    "test:packages": "bun --filter './packages/*' test && bun --filter './packages/nodes/*' test",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "electbun:dev": "concurrently -k -n VITE,ELECTBUN -c green,cyan \"vite\" \"bun run electron/main.ts\"",
    "electbun:build": "vite build && bun build electron/main.ts --outfile=electron/main.bundle.js",
    "electbun:start": "bun run electron/main.ts"
  },
  "dependencies": {
    "@xiranite/contract": "workspace:*",
    "@xiranite/node-cleanf": "workspace:*",
    "@xiranite/node-crashu": "workspace:*",
    "@xiranite/node-dissolvef": "workspace:*",
    "@xiranite/node-encodeb": "workspace:*",
    "@xiranite/node-lata": "workspace:*",
    "@xiranite/node-linedup": "workspace:*",
    "@xiranite/node-linku": "workspace:*",
    "@xiranite/node-migratef": "workspace:*",
    "@xiranite/node-movea": "workspace:*",
    "@xiranite/node-owithu": "workspace:*",
    "@xiranite/node-rawfilter": "workspace:*",
    "@xiranite/node-recycleu": "workspace:*",
    "@xiranite/node-reinstallp": "workspace:*",
    "@xiranite/node-scoolp": "workspace:*",
    "@xiranite/node-seriex": "workspace:*",
    "@xiranite/node-sleept": "workspace:*",
    "@xiranite/ui": "workspace:*",
    "@base-ui/react": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hibernalglow/ocean-dataview": "file:vendor/ocean-dataview",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.11.1",
    "chrono-node": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dockview-react": "^7.0.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.6.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.7.6",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
