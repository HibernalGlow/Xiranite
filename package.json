{
  "name": "xiranite",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "packages/*",
    "packages/nodes/*"
  ],
  "scripts": {
    "dev": "bun run generate:node-registries && bun run build:packages:lazy && bun scripts/dev-with-backend.ts",
    "dev:desktop": "bun run generate:node-registries && bun run build:packages:lazy && bun scripts/dev-desktop.ts",
    "dev:desktop:attach": "bun run generate:node-registries && bun run build:packages:lazy && bun scripts/dev-desktop-attach.ts",
    "dev:vite": "vite",
    "build": "bun run generate:node-registries && bun run build:packages:lazy && tsc -b && vite build && bun run audit:build-chunks",
    "build:base-packages": "bun --filter @xiranite/config build && bun --filter @xiranite/contract build && bun --filter @xiranite/shared build && bun --filter @xiranite/cli-runtime build && bun --filter @xiranite/repository build && bun --filter @xiranite/services build && bun --filter @xiranite/api build",
    "build:nodes": "bun --filter './packages/nodes/*' build",
    "build:packages": "bun run generate:node-registries && bun run build:base-packages && bun run build:nodes && bun --filter @xiranite/runtime build && bun --filter @xiranite/backend build && bun --filter @xiranite/cli build",
    "build:packages:lazy": "bun scripts/build-packages-lazy.ts",
    "build:packages:turbo": "turbo run build --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "test:packages:turbo": "turbo run test --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "build:backend:js": "bun scripts/build-backend-js.ts",
    "generate:node-registries": "bun scripts/generate-node-registries.ts",
    "migrate:node-ui": "bun scripts/migrate-node-ui-to-app.ts",
    "sync:cli-bins": "bun scripts/sync-cli-bin-names.ts",
    "audit:node-architecture": "bun scripts/validate-node-architecture.ts",
    "audit:node-tests": "bun scripts/audit-node-tests.ts",
    "audit:node-ui-quality": "bun scripts/audit-node-ui-quality.ts",
    "audit:node-runtime-risks": "bun scripts/audit-node-runtime-risks.ts",
    "audit:build-chunks": "bun scripts/audit-build-chunks.ts",
    "qa:card": "bun scripts/qa-card.ts",
    "test:unit": "vitest run --dir . --exclude \"**/dist/**\" --exclude \"**/artifacts/**\" --exclude \"**/build/**\" --exclude \"**/vendor/**\" --exclude \"**/ref/**\" --exclude \"**/tests/e2e/**\"",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:packages": "bun run generate:node-registries && bun run build:base-packages && bun run build:nodes && bun run audit:node-architecture && bun --filter @xiranite/runtime build && bun --filter @xiranite/backend build && bun --filter './packages/*' test && bun --filter './packages/nodes/*' test",
    "typecheck": "bun run generate:node-registries && tsc --noEmit",
    "typecheck:tsgo": "bun run generate:node-registries && tsgo --noEmit",
    "typecheck:tsgo:raw": "tsgo --noEmit",
    "build:refs:tsgo": "tsgo -b",
    "preview": "vite preview",
    "wails:dev": "bun run dev:desktop",
    "wails:syso": "go run -mod=mod github.com/wailsapp/wails/v3/cmd/wails3@v3.0.0-alpha.98 generate syso -arch amd64 -icon build/windows/icon.ico -manifest build/windows/wails.exe.manifest -info build/windows/info.json -out wails_windows_amd64.syso",
    "wails:build": "bun run build && bun run build:backend:js && bun run wails:syso && go build -mod=mod -tags production -ldflags=\"-w -s -H windowsgui\" -o build/wails/Xiranite.exe .",
    "wails:start": "go run -mod=mod ."
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@blocknote/shadcn": "^0.51.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hibernalglow/ocean-dataview": "file:vendor/ocean-dataview",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-table": "^8.21.3",
    "@wailsio/runtime": "latest",
    "@xiranite/api": "workspace:*",
    "@xiranite/contract": "workspace:*",
    "@xiranite/node-bandia": "workspace:*",
    "@xiranite/node-cleanf": "workspace:*",
    "@xiranite/node-crashu": "workspace:*",
    "@xiranite/node-dissolvef": "workspace:*",
    "@xiranite/node-encodeb": "workspace:*",
    "@xiranite/node-enginev": "workspace:*",
    "@xiranite/node-findz": "workspace:*",
    "@xiranite/node-formatv": "workspace:*",
    "@xiranite/node-kavvka": "workspace:*",
    "@xiranite/node-lata": "workspace:*",
    "@xiranite/node-linedup": "workspace:*",
    "@xiranite/node-linku": "workspace:*",
    "@xiranite/node-lorat": "workspace:*",
    "@xiranite/node-marku": "workspace:*",
    "@xiranite/node-migratef": "workspace:*",
    "@xiranite/node-movea": "workspace:*",
    "@xiranite/node-mvz": "workspace:*",
    "@xiranite/node-owithu": "workspace:*",
    "@xiranite/node-rawfilter": "workspace:*",
    "@xiranite/node-recycleu": "workspace:*",
    "@xiranite/node-repacku": "workspace:*",
    "@xiranite/node-scoolp": "workspace:*",
    "@xiranite/node-seriex": "workspace:*",
    "@xiranite/node-sleept": "workspace:*",
    "@xiranite/node-trename": "workspace:*",
    "@xiranite/runtime": "workspace:*",
    "@xiranite/shared": "workspace:*",
    "chrono-node": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dockview-react": "^7.0.2",
    "gridstack": "^12.6.0",
    "i18next": "^26.3.4",
    "lucide-react": "^1.6.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "react-resizable-panels": "^4.7.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.10.6",
    "msw": "^2.14.6",
    "node-pty": "^1.1.0",
    "turbo": "^2.10.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.10"
  }
}
