{
  "name": "@xiranite/node-transq",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "PackU TransQ translation result organizer node.",
  "license": "UNLICENSED",
  "bin": {
    "xtransq": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./help": {
      "types": "./dist/help.d.ts",
      "default": "./dist/help.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@xiranite/contract": "workspace:*",
    "@xiranite/packu-node-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
