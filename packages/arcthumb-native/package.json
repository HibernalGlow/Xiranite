{
  "name": "@xiranite/arcthumb-native",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Typed Node-API loader for Xiranite's ArcThumb Rust core.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "native"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "build:native": "bun scripts/build-native.ts",
    "benchmark:system-thumbnail": "bun scripts/benchmark-system-thumbnail.mjs",
    "smoke:native": "bun run build && bun scripts/smoke-native.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^7.0.2"
  }
}
