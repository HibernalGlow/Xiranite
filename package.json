    "@xiranite/node-transq": "workspace:*",
    "@xiranite/node-trename": "workspace:*",
    "@xiranite/node-vert": "workspace:*",
    "@xiranite/node-xlchemy": "workspace:*",
    "@xiranite/packu-node-runtime": "workspace:*",
    "@xiranite/runtime": "workspace:*",
    "@xiranite/shared": "workspace:*",
    "@xyflow/react": "^12.11.2",
