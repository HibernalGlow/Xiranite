{
  "name": "@xiranite/cli",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "Aggregate Xiranite CLI that dispatches to installed node package commands.",
  "license": "UNLICENSED",
  "bin": {
    "xiranite": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test"
  },
