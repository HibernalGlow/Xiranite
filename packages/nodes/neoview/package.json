{
  "name": "@xiranite/node-neoview",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "NeoView reader core and shared GUI/CLI/TUI contracts.",
  "license": "UNLICENSED",
  "bin": {
    "xneoview": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./help": {
      "types": "./dist/help.d.ts",
      "default": "./dist/help.js"
    },
    "./interaction": {
      "types": "./dist/interaction.d.ts",
      "default": "./dist/interaction.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "test": "vitest run src --environment node --exclude src/testing/Tui.bun.test.tsx && bun test src/testing/Tui.bun.test.tsx"
  },
  "dependencies": {
    "@xiranite/arcthumb-native": "workspace:*",
    "@xiranite/cli-runtime": "workspace:*",
    "@xiranite/config": "workspace:*",
    "@xiranite/contract": "workspace:*",
    "@xiranite/services": "workspace:*",
    "@zip.js/zip.js": "^2.8.26",
    "fluent-ffmpeg": "2.1.3",
    "lz4-napi": "2.9.1",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "2.1.28",
    "@types/node": "^24.12.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
