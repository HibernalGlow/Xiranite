{
  "name": "@xiranite/node-vert",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "Universal local format converter inspired by VERT, with native CLI-first execution and WebAssembly fallback.",
  "license": "AGPL-3.0-or-later",
  "bin": {
    "xvert": "./dist/cli.js"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./core": { "types": "./dist/core.d.ts", "default": "./dist/core.js" },
    "./help": { "types": "./dist/help.d.ts", "default": "./dist/help.js" },
    "./interaction": { "types": "./dist/interaction.d.ts", "default": "./dist/interaction.js" },
    "./cli": { "types": "./dist/cli.d.ts", "default": "./dist/cli.js" },
    "./platform": { "types": "./dist/platform.d.ts", "default": "./dist/platform.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:tsc": "tsc -p tsconfig.json",
    "test": "node ../../../node_modules/vitest/vitest.mjs run src --environment node --exclude src/Tui.bun.test.tsx && bun test src/Tui.bun.test.tsx"
  },
  "dependencies": {
    "@xiranite/cli-runtime": "workspace:*",
    "@xiranite/config": "workspace:*",
    "@xiranite/contract": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^7.0.2"
  }
}
