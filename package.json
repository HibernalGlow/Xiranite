{
  "name": "xiranite",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "overrides": {
    "@img/sharp-win32-x64": "npm:@img-custom/sharp-win32-x64@0.35.3",
    "p-map": "4.0.0"
  },
  "workspaces": [
    "packages/*",
    "packages/nodes/*"
  ],
  "scripts": {
    "dev": "bun run generate:node-registries && bun run build:desktop:packages && bun scripts/dev-with-backend.ts",
    "dev:clean": "bun scripts/reset-vite-dev.ts && bun run dev -- --force",
    "dev:desktop": "bun run generate:node-registries && bun run build:desktop:packages && bun scripts/dev-desktop.ts",
    "dev:desktop:clean": "bun scripts/reset-vite-dev.ts && bun run dev:desktop -- --force",
    "dev:desktop:attach": "bun run generate:node-registries && bun run build:desktop:packages && bun scripts/dev-desktop-attach.ts",
    "dev:desktop:deno": "bun scripts/reset-vite-dev.ts && bun run generate:node-registries && bun run build:packages:turbo && bun scripts/dev-desktop-deno.ts --force",
    "dev:desktop:deno:attach": "bun run generate:node-registries && bun run build:packages:turbo && bun scripts/dev-desktop-deno-attach.ts",
    "dev:vite": "vite",
    "dev:vite:clean": "bun scripts/reset-vite-dev.ts && vite --force",
    "build": "bun run generate:node-registries && bun run build:packages:turbo && bun run typecheck && vite build && bun run audit:build-chunks",
    "build:base-packages": "bun scripts/run-turbo.ts build --filter=@xiranite/config --filter=@xiranite/contract --filter=@xiranite/shared --filter=@xiranite/cli-runtime --filter=@xiranite/packu-node-runtime --filter=@xiranite/repository --filter=@xiranite/services --filter=@xiranite/api",
    "build:nodes": "bun scripts/run-turbo.ts build --filter=\"./packages/nodes/*\"",
    "build:packages": "bun run generate:node-registries && bun scripts/run-turbo.ts build --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "build:packages:legacy": "bun scripts/build-packages-lazy.ts",
    "build:packages:local": "bun scripts/build-packages-lazy.ts --skip-failed-nodes",
    "build:desktop:packages": "bun scripts/build-desktop-packages.ts",
    "build:packages:turbo": "bun scripts/run-turbo.ts build --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "build:packages:tsc": "bun scripts/run-turbo.ts build:tsc --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "test:packages:turbo": "bun scripts/run-turbo.ts test --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "build:backend:js": "bun scripts/build-backend-js.ts",
    "build:native-assets": "bun run --cwd packages/czkawka-native prepare:embedded",
    "refresh:native-assets": "bun run --cwd packages/czkawka-native refresh:prebuilt",
    "refresh:native-assets:existing": "bun run --cwd packages/czkawka-native refresh:prebuilt:existing",
    "build:backend:deno": "bun scripts/build-backend-js.ts build/deno/xiranite-backend.js",
    "build:desktop:deno": "bun scripts/build-desktop-deno.ts",
    "check:desktop:deno": "bun scripts/check-desktop-deno.ts",
    "generate:node-registries": "bun scripts/generate-node-registries.ts",
    "lint": "oxlint .",
    "lint:all": "bun run lint && bun run audit:node-architecture",
    "migrate:node-ui": "bun scripts/migrate-node-ui-to-app.ts",
    "migrate:tauri": "bun packages/tauri-migrate/src/cli.ts",
    "migrate:svelte": "bun packages/svelte-migrate/src/cli.ts",
    "sync:cli-bins": "bun scripts/sync-cli-bin-names.ts",
    "sync:ui-registries": "bun scripts/sync-ui-registries.ts",
    "audit:node-architecture": "bun scripts/validate-node-architecture.ts",
    "audit:node-help": "bun scripts/validate-node-help.ts",
    "audit:node-tests": "bun scripts/audit-node-tests.ts",
    "audit:node-ui-quality": "bun scripts/audit-node-ui-quality.ts",
    "audit:node-runtime-risks": "bun scripts/audit-node-runtime-risks.ts",
    "audit:react-compiler-boundaries": "bun scripts/validate-react-compiler-boundaries.ts",
    "audit:tui": "node --experimental-strip-types scripts/audit-node-tuis.ts",
    "audit:build-chunks": "bun scripts/audit-build-chunks.ts",
    "audit:neoview-inventory": "bun scripts/verify-neoview-inventory-drift.ts",
    "audit:neoview-frontend": "bun scripts/verify-neoview-frontend-inventory.ts",
    "audit:neoview-features": "bun scripts/verify-neoview-feature-matrix.ts",
    "audit:neoview-cards": "bun scripts/verify-neoview-card-matrix.ts",
    "audit:neoview-card-checklists": "bun scripts/verify-neoview-card-checklists.ts && bun scripts/generate-neoview-card-checklist-doc.ts --check",
    "audit:neoview-build": "bun scripts/audit-neoview-build-chunk.ts",
    "generate:neoview-frontend-inventory": "bun run migrate:svelte -- generate ../ImageAll/NeeWaifu/neoview/neoview-tauri --out migration/neoview/frontend --config migration/neoview/frontend-migration.json --feature-matrix migration/neoview/feature-compatibility.json --force",
    "generate:neoview-feature-checklist": "bun scripts/verify-neoview-feature-matrix.ts --update-doc",
    "generate:neoview-card-sources": "bun scripts/freeze-neoview-card-sources.ts",
    "generate:neoview-card-checklist": "bun scripts/generate-neoview-card-checklist-doc.ts",
    "qa:card": "bun scripts/qa-card.ts",
    "qa:node-baselines": "bun scripts/capture-node-gui-baselines.ts",
    "benchmark:react-compiler": "bun scripts/benchmark-react-compiler.ts",
    "benchmark:neoview-zip": "bun scripts/benchmark-neoview-zip.ts",
    "benchmark:neoview-cache": "bun scripts/benchmark-neoview-cache.ts",
    "benchmark:neoview-disk-cache": "bun scripts/benchmark-neoview-disk-cache.ts",
    "benchmark:neoview-thumbnails": "bun scripts/benchmark-neoview-thumbnails.ts",
    "benchmark:neoview-thumbnail-system": "bun scripts/benchmark-neoview-thumbnail-system.ts",
    "benchmark:neoview-codecs": "bun scripts/benchmark-neoview-image-codecs.ts",
    "benchmark:neoview-sevenzip": "bun scripts/benchmark-neoview-sevenzip.ts",
    "benchmark:neoview-reader": "bun scripts/benchmark-neoview-reader.ts",
    "audit:neoview-performance": "bun scripts/verify-neoview-performance.ts",
    "test:unit": "vitest run --dir . --exclude \"**/dist/**\" --exclude \"**/artifacts/**\" --exclude \"**/build/**\" --exclude \"**/vendor/**\" --exclude \"**/ref/**\" --exclude \"**/tests/e2e/**\"",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:packages": "bun run generate:node-registries && bun scripts/run-turbo.ts build --filter=\"./packages/*\" --filter=\"./packages/nodes/*\" && bun run audit:node-architecture && bun scripts/run-turbo.ts test --filter=\"./packages/*\" --filter=\"./packages/nodes/*\"",
    "typecheck": "bun run generate:node-registries && tsc --noEmit",
    "typecheck:app": "tsgo --noEmit",
    "typecheck:tsc": "bun run typecheck",
    "build:refs": "tsc -b",
    "preview": "vite preview",
    "release": "bun scripts/release.ts",
    "release:dry": "bun scripts/release.ts --dry-run",
    "release:patch": "bun scripts/release.ts patch",
    "release:minor": "bun scripts/release.ts minor",
    "release:major": "bun scripts/release.ts major",
    "wails:dev": "bun run dev:desktop",
    "wails:syso": "go run -mod=mod github.com/wailsapp/wails/v3/cmd/wails3@v3.0.0-alpha.98 generate syso -arch amd64 -icon build/windows/icon.ico -manifest build/windows/wails.exe.manifest -info build/windows/info.json -out wails_windows_amd64.syso",
    "wails:build": "bun run build && bun run build:backend:js && bun run build:native-assets && bun run wails:syso && go build -mod=mod -tags production -ldflags=\"-w -s -H windowsgui\" -o build/wails/Xiranite.exe .",
    "wails:build:local": "bun scripts/build-wails-local.ts",
    "wails:start": "go run -mod=mod ."
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@blocknote/core": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@blocknote/shadcn": "^0.51.4",
    "@diceui/tags-input": "^0.7.2",
