{
  "name": "@xiranite/node-neoview",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "NeoView reader core and shared GUI/CLI/TUI contracts.",
  "license": "UNLICENSED",
  "bin": {
    "xneoview": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./ui-core": {
      "types": "./dist/ui-core.d.ts",
      "default": "./dist/ui-core.js"
    },
    "./color-filter": {
      "types": "./dist/color-filter.d.ts",
      "default": "./dist/color-filter.js"
    },
    "./page-transition": {
      "types": "./dist/page-transition.d.ts",
      "default": "./dist/page-transition.js"
    },
    "./switch-toast": {
      "types": "./dist/switch-toast.d.ts",
      "default": "./dist/switch-toast.js"
    },
    "./time-information": {
      "types": "./dist/time-information.d.ts",
      "default": "./dist/time-information.js"
    },
    "./book-information": {
      "types": "./dist/book-information.d.ts",
      "default": "./dist/book-information.js"
    },
    "./info-overlay": {
      "types": "./dist/info-overlay.d.ts",
      "default": "./dist/info-overlay.js"
    },
    "./image-trim": {
      "types": "./dist/image-trim.d.ts",
      "default": "./dist/image-trim.js"
    },
    "./animated-video": {
      "types": "./dist/animated-video.d.ts",
      "default": "./dist/animated-video.js"
    },
    "./definition": {
      "types": "./dist/definition.d.ts",
      "default": "./dist/definition.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./help": {
      "types": "./dist/help.d.ts",
      "default": "./dist/help.js"
    },
    "./interaction": {
      "types": "./dist/interaction.d.ts",
      "default": "./dist/interaction.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "build:tsc": "bun scripts/build.ts",
    "test": "vitest run src --environment node --exclude src/testing/Tui.bun.test.tsx && bun test src/testing/Tui.bun.test.tsx"
  },
  "dependencies": {
    "@hibernalglow/opencomic-ai-system": "github:HibernalGlow/opencomic-ai-bin#cc83499463e68cc893c8b67d12c6e0bf375081a7",
    "@parcel/watcher": "^2.5.6",
    "@xiranite/arcthumb-native": "workspace:*",
    "@xiranite/cli-runtime": "workspace:*",
    "@xiranite/config": "workspace:*",
    "@xiranite/contract": "workspace:*",
    "@xiranite/services": "workspace:*",
    "@zip.js/zip.js": "^2.8.26",
    "cacache": "20.0.1",
    "fast-xml-parser": "5.3.6",
    "fluent-ffmpeg": "2.1.3",
    "ignore": "7.0.6",
    "image-size": "2.0.2",
    "lru-cache": "11.5.2",
    "lz4js": "0.2.0",
    "move-file": "4.1.0",
    "open": "11.0.0",
    "p-map": "4.0.0",
    "picomatch": "4.0.5",
    "proper-lockfile": "4.1.2",
    "readdirp": "^5.0.0",
    "reveal-file": "0.1.2",
    "sharp": "0.35.3",
    "subsrt": "1.1.1",
    "trash": "10.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cacache": "20.0.1",
    "@types/fluent-ffmpeg": "2.1.28",
    "@types/lz4js": "0.2.2",
    "@types/node": "^24.12.0",
    "@types/picomatch": "4.0.3",
    "@types/proper-lockfile": "4.1.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
